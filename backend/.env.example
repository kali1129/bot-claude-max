# Backend dashboard env. Copy to .env and fill in.

# MongoDB. Local dev: docker run -p 27017:27017 -d mongo:7
MONGO_URL=mongodb://localhost:27017
DB_NAME=trading_dashboard

# Single-tenant token for write endpoints (POST/PUT/DELETE on journal + checklist).
# Leave empty to disable auth in dev. Generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
DASHBOARD_TOKEN=

# Comma-separated list of allowed origins for CORS. Defaults to localhost dev URLs.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Bind host for uvicorn. Use 127.0.0.1 to lock to local; 0.0.0.0 only behind a reverse proxy.
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
