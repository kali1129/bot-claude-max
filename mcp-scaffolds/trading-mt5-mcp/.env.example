# MT5 credentials. Use INVESTOR password until you graduate to live trading.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Trading mode: paper (no MT5 calls), demo (MT5 demo), live (MT5 real). Default: paper.
TRADING_MODE=paper

# Hardcoded constants are in server.py; these only fine-tune secondary limits.
MAX_LOTS_PER_TRADE=0.5
BLOCKED_HOURS_UTC=21:00-07:00

# Magic number identifies trades placed by this MCP in MT5 history.
# Pick any unique 8-digit int (e.g. yyyymmdd of first deploy).
MT5_MAGIC=20260427

# Kill-switch file path. Trading-mcp refuses place_order while this exists.
HALT_FILE=~/mcp/.HALT

# Dashboard sync. Each closed deal is POSTed to this URL with idempotency key.
DASHBOARD_URL=http://localhost:8000
DASHBOARD_TOKEN=

LOG_LEVEL=INFO
LOG_DIR=~/mcp/logs
