# MT5 credentials. Use INVESTOR password until you graduate to live trading.
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Trading mode: paper (no MT5 calls, tests only), demo (real broker demo
# orders), live (real money). Default: demo. paper is for unit tests only —
# it never produces real fills, slippage, or rejections, so it tells you
# nothing about whether the bot actually trades on a real connection.
TRADING_MODE=demo

# IMPORTANT — broker time zone:
# The daily-DD guard and `_today_trade_stats()` use UTC midnight as the
# day boundary. Most XM / IC / FXPro etc. brokers run their MT5 history
# in UTC+0 or UTC+3 (FX broker default). If your broker's history clock
# is NOT UTC, the daily checks will be off by 0-7 hours around midnight.
# Verify by reading `mt5.terminal_info().timezone` or by spot-checking a
# closed deal's reported time vs your wall clock. If you see drift, set
# the broker server to a UTC-aligned profile or document the offset here.

# Hardcoded constants are in server.py; these only fine-tune secondary limits.
MAX_LOTS_PER_TRADE=0.5
BLOCKED_HOURS_UTC=21:00-07:00

# Magic number identifies trades placed by this MCP in MT5 history.
# Pick any unique 8-digit int (e.g. yyyymmdd of first deploy).
MT5_MAGIC=20260427

# Kill-switch file path. Trading-mcp refuses place_order while this exists.
HALT_FILE=~/mcp/.HALT

# Dashboard sync. Each closed deal is POSTed to this URL with idempotency key.
DASHBOARD_URL=http://localhost:8000
DASHBOARD_TOKEN=

LOG_LEVEL=INFO
LOG_DIR=~/mcp/logs
